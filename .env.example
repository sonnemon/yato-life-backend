# Server
PORT=3000
NODE_ENV=development

# Supabase (server-side only — never ship these to the Electron client)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Only needed when AUTH_VERIFY_STRATEGY=hs256
SUPABASE_JWT_SECRET=

# JWT verification: getuser (default) | jwks | hs256
AUTH_VERIFY_STRATEGY=getuser

# Secret to sign the short-lived OAuth `state` token (any long random string).
# Generate one with:  openssl rand -hex 32
OAUTH_STATE_SECRET=

# Google Calendar OAuth (server-handled callback). Point the redirect at THIS API.
# The redirect URI must EXACTLY match one registered in the Google Cloud console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/calendar/google/callback

# Deep link Electron is refocused to after OAuth completes
OAUTH_SUCCESS_DEEP_LINK=yato://oauth/callback
